{
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": [
    {
      "target": "usuario",
      "public": "APP_USUARIO",
      "ignore": ["**/node_modules/**", "**/.git/**", "**/README*"],
      "headers": [
        {
          "source": "**/*.@(js|mjs)",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
        },
        {
          "source": "**/*.@(css|png|jpg|svg|ico|webp)",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
        },
        {
          "source": "**",
          "headers": [{ "key": "X-Frame-Options", "value": "SAMEORIGIN" }]
        }
      ],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "conductor",
      "public": "conductor",
      "ignore": ["**/node_modules/**", "**/.git/**", "**/README*", "**/package*.json"],
      "headers": [
        {
          "source": "**/*.@(js)",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
        },
        {
          "source": "**/*.@(css|png|jpg|svg|ico)",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
        },
        {
          "source": "**",
          "headers": [{ "key": "X-Frame-Options", "value": "SAMEORIGIN" }]
        }
      ],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "base",
      "public": "base",
      "ignore": ["**/node_modules/**", "**/.git/**", "**/README*", "**/*.zip"],
      "headers": [
        {
          "source": "**/*.@(js|css)",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
        },
        {
          "source": "**",
          "headers": [{ "key": "X-Frame-Options", "value": "SAMEORIGIN" }]
        }
      ],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    }
  ]
}
