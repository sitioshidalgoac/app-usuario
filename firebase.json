{
  "functions": {
    "source": "functions"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": [
    {
      "target": "usuario",
      "public": "APP_USUARIO",
      "ignore": ["**/node_modules/**", "**/.git/**", "**/README*"],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "conductor",
      "public": "conductor",
      "ignore": ["**/node_modules/**", "**/.git/**", "**/README*", "**/package*.json"],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "base",
      "public": "base-gps",
      "ignore": ["**/node_modules/**", "**/.git/**", "**/README*", "**/*.zip"],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    }
  ]
}
